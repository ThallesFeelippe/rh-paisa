generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String   @id @default(cuid())
  role            String   // ADMIN, SECRETARIA, PSICOLOGA
  username        String   @unique
  password        String
  name            String
  avatarUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  messagesSent    Message[]
}

model Employee {
  id              String   @id @default(cuid())
  name            String
  cpf             String   @unique
  rg              String?
  birthDate       DateTime?
  sectorId        String
  sector          Sector   @relation(fields: [sectorId], references: [id])
  position        String   // Cargo
  salary          Float?
  startDate       DateTime
  isApprentice    Boolean  @default(false)
  contractEnd     DateTime? // For apprentices
  photoUrl        String?
  documentPdfUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Sector {
  id              String   @id @default(cuid())
  name            String   @unique
  employees       Employee[]
  createdAt       DateTime @default(now())
}

model ChatRoom {
  id              String   @id @default(cuid())
  name            String?
  messages        Message[]
  isActive        Boolean  @default(true)
}

model Message {
  id              String   @id @default(cuid())
  content         String
  senderId        String
  sender          User     @relation(fields: [senderId], references: [id])
  roomId          String
  room            ChatRoom @relation(fields: [roomId], references: [id])
  createdAt       DateTime @default(now())
}

model Job {
  id              String   @id @default(cuid())
  title           String
  area            String   // Operacional, Administrativo, Tecnologia, Engenharia
  location        String
  type            String   // CLT, Presencial, Híbrido, PJ
  description     String
  requirements    String?
  benefits        String?
  status          String   @default("PUBLICO") // PUBLICO, RASCUNHO, ENCERRADA
  applications    Application[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Application {
  id              String   @id @default(cuid())
  name            String
  age             Int
  cpf             String
  education       String
  maritalStatus   String
  email           String
  phone           String
  address         String
  photoUrl        String?
  resumeUrl       String?
  motivation      String?
  jobId           String?
  job             Job?     @relation(fields: [jobId], references: [id])
  createdAt       DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  location    String
  date        String
  description String
  images      String   // JSON stringified array of image URLs
  
  // New dynamic fields for the report page
  status            String?  @default("Concluído")
  category          String?  @default("Social")
  responsible       String?  @default("RH Paisa")
  impactTitle       String?  @default("Impacto Gerado")
  impactDescription String?  @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model News {
  id              String   @id @default(cuid())
  title           String
  slug            String?  @unique
  excerpt         String?
  content         String
  image           String?  // Main image
  videoUrl        String?  // Embed URL or internal path
  gallery         String?  // JSON stringified array of images
  category        String?  @default("Geral")
  tags            String?  // Comma-separated tags
  status          String   @default("PUBLICO") // PUBLICO, RASCUNHO
  authorName      String?  @default("Comunicação Paisa")
  authorAvatar    String?
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

