generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String   @id @default(cuid())
  role            String   // ADMIN, SECRETARIA, PSICOLOGA, GESTOR_RH
  username        String   @unique
  password        String
  name            String
  avatarUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  messagesSent    Message[]
}

model Employee {
  id                String   @id @default(cuid())
  name              String
  registrationNumber String?  @unique // Matrícula
  cpf               String   @unique
  rg                String?
  birthDate         DateTime?
  sectorId          String?
  sector            Sector?  @relation(fields: [sectorId], references: [id])
  position          String   // Cargo
  salary            Float?
  startDate         DateTime
  isApprentice      Boolean  @default(false)
  contractEnd       DateTime? // For apprentices
  
  // RH Fields
  educationLevel    String?  // Fundamental, Médio, Superior, etc.
  educationDetail   String?  // Ex: 7º Período de Direito
  careerPlan        String?  // Structured text or JSON
  
  // Apprentice Specific
  observationApprentice String?
  grades            String?  // Notas
  description       String?  // Descrição detalhada
  
  // Location
  workLocationId    String?
  workLocation      WorkLocation? @relation(fields: [workLocationId], references: [id])
  
  photoUrl          String?
  documents         EmployeeDocument[]
  courses           Course[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model EmployeeDocument {
  id          String   @id @default(cuid())
  name        String
  url         String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Course {
  id              String   @id @default(cuid())
  name            String
  institution     String
  completionDate  DateTime?
  certificateUrl  String?
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model WorkLocation {
  id          String   @id @default(cuid())
  name        String   @unique // Ex: Usina Paisa, RH, CIEE
  category    String?  // RURAL, URBANA, ADMINISTRATIVA (only for root areas)
  
  // Hierarchy
  parentId    String?
  parent      WorkLocation?  @relation("WorkLocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    WorkLocation[] @relation("WorkLocationHierarchy")

  employees   Employee[]
  createdAt   DateTime @default(now())
}

model Sector {
  id              String   @id @default(cuid())
  name            String   @unique
  employees       Employee[]
  createdAt       DateTime @default(now())
}

model ChatRoom {
  id              String   @id @default(cuid())
  name            String?
  messages        Message[]
  isActive        Boolean  @default(true)
}

model Message {
  id              String   @id @default(cuid())
  content         String
  senderId        String
  sender          User     @relation(fields: [senderId], references: [id])
  roomId          String
  room            ChatRoom @relation(fields: [roomId], references: [id])
  createdAt       DateTime @default(now())
}

model Job {
  id              String   @id @default(cuid())
  title           String
  area            String   // Operacional, Administrativo, Tecnologia, Engenharia
  location        String
  type            String   // CLT, Presencial, Híbrido, PJ
  description     String
  requirements    String?
  benefits        String?
  status          String   @default("PUBLICO") // PUBLICO, RASCUNHO, ENCERRADA
  applications    Application[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Application {
  id              String   @id @default(cuid())
  name            String
  age             Int
  cpf             String
  education       String
  maritalStatus   String
  email           String
  phone           String
  address         String
  photoUrl        String?
  resumeUrl       String?
  motivation      String?
  jobId           String?
  job             Job?     @relation(fields: [jobId], references: [id])
  createdAt       DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  location    String
  date        String
  description String
  images      String   // JSON stringified array of image URLs
  
  // New dynamic fields for the report page
  status            String?  @default("Concluído")
  category          String?  @default("Social")
  responsible       String?  @default("RH Paisa")
  impactTitle       String?  @default("Impacto Gerado")
  impactDescription String?  @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model News {
  id              String   @id @default(cuid())
  title           String
  slug            String?  @unique
  excerpt         String?
  content         String
  image           String?  // Main image
  videoUrl        String?  // Embed URL or internal path
  gallery         String?  // JSON stringified array of images
  category        String?  @default("Geral")
  tags            String?  // Comma-separated tags
  status          String   @default("PUBLICO") // PUBLICO, RASCUNHO
  authorName      String?  @default("Comunicação Paisa")
  authorAvatar    String?
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

